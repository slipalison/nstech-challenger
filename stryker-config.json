{
  "stryker-config": {
    "project": "src/NsTech.Application/NsTech.Application.csproj",
    "test-projects": [
      "tests/NsTech.Tests/NsTech.Tests.csproj"
    ],
    "mutate": [
      "**/*.cs",
      "!**/*ValidationBehavior.cs"
    ],
    "reporters": [
      "cleartext",
      "progress",
      "html",
      "markdown"
    ],
